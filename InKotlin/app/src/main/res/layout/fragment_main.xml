<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvWorkCyclesTitle"
        android:text="@string/cyclesText"
        android:layout_marginBottom="@dimen/common_padding_min"
        app:layout_constraintStart_toStartOf="@id/pbWorkCycle"
        app:layout_constraintEnd_toEndOf="@id/pbWorkCycle"
        app:layout_constraintBottom_toTopOf="@id/pbWorkCycle"/>
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:layout_width="128dp"
        android:layout_height="128dp"
        app:indicatorSize="64dp"
        android:indeterminate="false"
        android:progress="50"
        app:trackThickness="10dp"
        android:background="@drawable/lemon"
        app:trackCornerRadius="@dimen/common_padding_default"
        android:id="@+id/pbWorkCycle"
        app:layout_constraintStart_toStartOf="parent"
       app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/pbBreakCycle"
        android:layout_marginTop="64dp"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvWorkCycle"
        android:text="4"
        android:textStyle="bold"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="@id/pbWorkCycle"
        app:layout_constraintEnd_toEndOf="@id/pbWorkCycle"
        app:layout_constraintTop_toTopOf="@id/pbWorkCycle"
        app:layout_constraintBottom_toBottomOf="@id/pbWorkCycle"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvBreakCycleTitle"
        android:text="Descansos"
        android:layout_marginBottom="@dimen/common_padding_min"
        app:layout_constraintStart_toStartOf="@id/pbBreakCycle"
        app:layout_constraintEnd_toEndOf="@id/pbBreakCycle"
        app:layout_constraintBottom_toTopOf="@id/pbBreakCycle"/>
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:layout_width="128dp"
        android:layout_height="128dp"
        app:indicatorSize="@dimen/common_padding_max"
        android:indeterminate="false"
        android:progress="30"
        android:background="@drawable/lemon"
        app:trackCornerRadius="@dimen/common_padding_default"
        app:trackThickness="10dp"
        android:id="@+id/pbBreakCycle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/pbWorkCycle"
        app:layout_constraintBottom_toBottomOf="@id/pbWorkCycle"
        app:layout_constraintStart_toEndOf="@id/pbWorkCycle"

        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvBreakCycle"
        android:text="2"
        android:textStyle="bold"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="@id/pbBreakCycle"
        app:layout_constraintEnd_toEndOf="@id/pbBreakCycle"
        app:layout_constraintTop_toTopOf="@id/pbBreakCycle"
        app:layout_constraintBottom_toBottomOf="@id/pbBreakCycle"/>
    <!-- <ImageView
         android:layout_width="227dp"
         android:layout_height="227dp"
         android:id="@+id/ivLemon"
         android:src="@drawable/lemon"

         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         app:layout_constraintTop_toTopOf="parent"
         app:layout_constraintBottom_toBottomOf="parent"/>-->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:layout_width="128dp"
        android:layout_height="128dp"
        app:indicatorSize="211dp"
        android:indeterminate="false"
        tools:progress="50"
        app:trackThickness="20dp"
        android:background="@drawable/lemon"
        app:indicatorColor="@color/lemonProgressColor"
        app:trackCornerRadius="@dimen/common_padding_default"
        android:id="@+id/pbTimer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/tvMainCycle"
        tools:text="25:00"
        android:textStyle="bold"
        android:textSize="32sp"
        app:layout_constraintStart_toStartOf="@id/pbTimer"
        app:layout_constraintEnd_toEndOf="@id/pbTimer"
        app:layout_constraintTop_toTopOf="@id/pbTimer"
        app:layout_constraintBottom_toBottomOf="@id/pbTimer"/>
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/btnStop"
        app:icon="@drawable/ic_stop"

        style="@style/buttonsTimerStyle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pbTimer"
        app:layout_constraintEnd_toStartOf="@id/btnStart"
        />
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/btnStart"
        app:icon="@drawable/ic_play"

        style="@style/buttonsTimerStyle"
        app:layout_constraintStart_toEndOf="@id/btnStop"
        app:layout_constraintTop_toBottomOf="@id/pbTimer"
        app:layout_constraintEnd_toStartOf="@id/btnNext"
        />
    <com.google.android.material.button.MaterialButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/btnNext"
        app:icon="@drawable/ic_next"
        style="@style/buttonsTimerStyle"
        app:layout_constraintStart_toEndOf="@id/btnStart"
        app:layout_constraintTop_toBottomOf="@id/pbTimer"
        app:layout_constraintEnd_toEndOf="parent"
        />
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/fab_add_task"
        app:backgroundTint="@color/green_700"
        android:src="@drawable/ic_add"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="@dimen/common_padding_default"/>
</androidx.constraintlayout.widget.ConstraintLayout>